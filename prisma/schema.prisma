generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Delivery {
  id           String   @id @default(cuid())
  name         String
  address      String
  status       String   @default("pending")
  deliveryDate String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}